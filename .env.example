# TumorVision — Environment Variables
# Copy this file to .env and fill in your values
# Author: Rayen Lassoued | github.com/rayenx2

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=TumorVision
APP_VERSION=1.0.0
API_PREFIX=/api/v1
LOG_LEVEL=INFO
DEBUG=False

# ── Model ─────────────────────────────────────────────────────────────────────
# Hugging Face model repository for EfficientNetB4 weights
HF_MODEL_REPO=Himel000/kidney-tumor-efficientnetb4
HF_MODEL_FILENAME=model.keras
# Input image resolution (must match training resolution)
MODEL_IMAGE_SIZE=380
# Monte Carlo Dropout uncertainty threshold (0.0–1.0)
UNCERTAINTY_THRESHOLD=0.3

# ── Storage ───────────────────────────────────────────────────────────────────
# Local SQLite path used when Supabase is not configured
DATABASE_PATH=data/predictions.db
# Max upload size in megabytes
MAX_UPLOAD_SIZE_MB=10
# Temp directory for incoming uploads
TEMP_DIR=temp/uploads

# ── Redis (Celery async tasks — PDF report generation) ────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Supabase (optional — leave blank to use local SQLite) ─────────────────────
SUPABASE_URL=
SUPABASE_KEY=

# ── MLflow / DagsHub (optional — for experiment tracking) ─────────────────────
MLFLOW_TRACKING_URI=
DAGSHUB_USER_TOKEN=

# ── Training flags ─────────────────────────────────────────────────────────────
# Set to true to run model_training + model_evaluation stages via main.py
RUN_TRAINING=false
